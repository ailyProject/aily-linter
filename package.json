{
  "name": "aily-linter",
  "version": "1.0.0",
  "description": "Standalone multi-mode Arduino linter CLI",
  "main": "dist/main.js",
  "bin": {
    "aily-linter": "dist/main.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "benchmark": "npm run build && node bench/benchmark.js after",
    "start": "tsx main.ts",
    "smoke": "npm run build && node dist/main.js examples/blink.ino --mode fast --format json",
    "prepack": "npm run build"
  },
  "keywords": [
    "arduino",
    "lint",
    "static-analysis",
    "cli"
  ],
  "author": "coloz",
  "license": "GPL-3.0-only",
  "dependencies": {
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.4.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.16",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
