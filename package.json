{
  "name": "aily-linter",
  "version": "1.0.0",
  "description": "Standalone multi-mode Arduino linter CLI",
  "main": "dist/main.js",
  "bin": {
    "aily-linter": "dist/main.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "check": "tsc --noEmit",
    "start": "tsx main.ts",
    "smoke": "npm run build && node dist/main.js examples/blink.ino --mode fast --format json",
    "prepack": "npm run build"
  },
  "keywords": [
    "arduino",
    "lint",
    "static-analysis",
    "ast-grep",
    "cli"
  ],
  "author": "coloz",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@ast-grep/lang-cpp": "^0.0.4",
    "@ast-grep/napi": "^0.40.3",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.4.5",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cpp": "^0.23.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.16",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "tree-sitter-cpp": {
      "tree-sitter": "$tree-sitter"
    },
    "tree-sitter-c": {
      "tree-sitter": "$tree-sitter"
    }
  }
}
